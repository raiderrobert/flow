#!/usr/bin/env bash
# SessionStart hook for flow plugin

set -euo pipefail

cat <<EOF
{
  "additional_context": "You have flow skills available. Use the Skill tool to invoke them when relevant.",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "You have flow skills available. Use the Skill tool to invoke them when relevant."
  }
}
EOF

exit 0
